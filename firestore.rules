
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /clients/{clientId} {
      allow read, write: if request.auth != null; // Allow authenticated users to manage clients
    }
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null; // Allow authenticated users to manage services
    }
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
    match /sequences/{sequenceId} {
      allow read, write: if request.auth != null;
    }
     match /discounts/{discountId} {
      allow read, write: if request.auth != null;
    }
     match /complianceRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
    match /aiAccountantClients/{clientId}/{document=**} {
      allow read, write: if request.auth != null;
    }
     match /numeraClients/{clientId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /extractedInvoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }
     match /processedEmails/{emailId} {
      allow read, write: if request.auth != null;
    }
    match /allocationRules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Assuming admins should be able to write
    }
    match /unansweredQuestions/{questionId} {
      allow read, write: if request.auth != null;
    }
     match /communityQuestions/{questionId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
