
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if the user has an admin or staff role
    function isStaff() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // Lock down sequences, only backend can modify
    match /sequences/{docId} {
        allow read, write: if false;
    }

    // Users can only read their own data. Staff/Admins can read any user's data.
    // Users can only update their own data.
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow update: if isOwner(userId);
      allow create, delete: if isStaff();
    }
    
    // Numera Clients: Only staff/admins can access
    match /numeraClients/{clientId} {
      allow read, write: if isStaff();

      // Transactions subcollection for Numera clients
      match /transactions/{transactionId} {
        allow read, write: if isStaff();
      }
    }
    
    // Global allocation rules readable by staff, writable only by admins
    match /allocationRules/{ruleId} {
        allow read: if isStaff();
        allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Media can be read by anyone, but only written by authenticated users for their own uploads.
    match /media/{mediaId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uploadedBy == request.auth.uid;
    }

    // Services can be read by anyone, but only written by admins.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Categories can be read by anyone, but only written by admins.
    match /categories/{categoryId} {
        allow read: if true;
        allow write: if isStaff();
    }
    
    // Orders can be created by anyone, but only read/updated by the owner or staff.
    match /orders/{orderId} {
      allow create: if true; // Anyone can place an order
      allow read, update: if isStaff() || (request.auth != null && resource.data.resellerId == request.auth.uid);
      allow delete: if false;
    }

    // Blog posts can be read by anyone, but only written by staff/admins.
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Discounts can only be managed by staff/admins.
    match /discounts/{discountId} {
      allow read, write, create, delete: if isStaff();
    }
    
    // Compliance requests can be created by anyone, read by staff.
    match /complianceRequests/{reqId} {
      allow create: if true;
      allow read, delete: if isStaff();
    }
    
    // Tasks are only accessible by staff/admins.
    match /tasks/{taskId} {
      allow read, write: if isStaff();
    }
    
    // Unanswered questions can be created by anyone, read/deleted by staff.
    match /unansweredQuestions/{questionId} {
      allow create: if true;
      allow read, delete: if isStaff();
    }
    
    // Community Questions & Answers
    match /communityQuestions/{questionId} {
      // Anyone can read approved questions
      allow read: if resource.data.status == 'approved';
      // Authenticated users can create questions
      allow create: if request.auth != null;
      // Only admins/staff can approve/reject/delete
      allow update, delete: if isStaff();
      
      match /answers/{answerId} {
        // Authenticated users can post answers
        allow create: if request.auth != null;
        // Authenticated users can like answers (simplified rule)
        allow write: if request.auth != null;
        // Only question owner or admin can mark as best answer
        allow update: if isStaff() || get(/databases/$(database)/documents/communityQuestions/$(questionId)).data.askedBy == request.auth.uid;
      }
    }
  }
}
