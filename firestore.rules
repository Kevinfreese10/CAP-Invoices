rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow authenticated users to read profiles (names/roles)
      // and only allow users to edit their own profile
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }
    
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
    }
    
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }
    
    match /sequences/{sequenceId} {
      allow read, write: if isAuthenticated();
    }
    
    match /discounts/{discountId} {
      allow read, write: if isAuthenticated();
    }
    
    match /complianceRequests/{requestId} {
      allow read, write: if isAuthenticated();
    }
    
    match /aiAccountantClients/{clientId}/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    match /numeraClients/{clientId}/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    match /extractedInvoices/{invoiceId} {
      // Allow all authenticated users to read/write for now
      // Specific logic for suppliers to read their own is handled by query filters
      allow read, write: if isAuthenticated();
    }
    
    match /processedEmails/{emailId} {
      allow read, write: if isAuthenticated();
    }
    
    match /allocationRules/{ruleId} {
      allow read, write: if isAuthenticated();
    }
    
    match /unansweredQuestions/{questionId} {
      allow read, write: if isAuthenticated();
    }
    
    match /communityQuestions/{questionId}/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    match /commissionData/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /commissions/{commissionId} {
      // Allow all authenticated users to see the commission list
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}