rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow writes to the invoices folder only for the specific admin user
    match /invoices/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == '2';
    }
    
    // Allow reads only by authenticated users who own the content
    match /{allPaths=**} {
      allow read: if request.auth != null && resource.metadata.owner == request.auth.uid;
    }
  }
}
