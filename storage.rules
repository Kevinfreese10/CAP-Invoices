rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files
    match /{allPaths=**} {
      allow read;
    }

    // Allow uploads to the user-specific invoices folder only for that user if they are admin or staff.
    match /invoices/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId &&
                      (exists(/databases/(default)/documents/users/$(userId)) &&
                       (get(/databases/(default)/documents/users/$(userId)).data.role == 'admin' ||
                        get(/databases/(default)/documents/users/$(userId)).data.role == 'staff'));
    }
    
    // Also keep the general uploads rule if it's used elsewhere.
    match /uploads/{fileName} {
      allow write: if request.auth != null && 
                      (exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
                       (get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'staff'));
    }
  }
}
