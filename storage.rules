rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Function to check if the user is an admin or staff from Firestore
    function isStaffOrAdmin() {
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    match /uploads/{allPaths=**} {
      // Only allow admin or staff to upload files
      allow write: if request.auth != null && isStaffOrAdmin();
      // Allow everyone to read files (e.g., to display images in the app)
      allow read;
    }
  }
}
