rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files for display on the website
    match /{allPaths=**} {
      allow read;
    }

    // Allow authenticated admins or staff to write to the 'uploads' folder.
    // This rule checks the user's role in the Firestore 'users' collection.
    match /uploads/{allPaths=**} {
      allow write: if request.auth != null && 
                      (exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
                       (get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'staff'));
    }
  }
}
