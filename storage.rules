rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Grant public read access to all files.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to write only to their own folder within 'invoices'.
    // The {userId} wildcard in the path is matched against the UID of the user making the request.
    match /invoices/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
